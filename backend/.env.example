# Django
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,hisabkitab-api.onrender.com

# Database (Neon.tech Postgres connection string). Leave unset to use local SQLite.
DATABASE_URL=postgresql://user:password@ep-example.neon.tech/hisabkitab?sslmode=require

# CORS - comma-separated list of allowed frontend origins
CORS_ALLOWED_ORIGINS=http://localhost:5173,https://hisabkitab.vercel.app

# Single-user auth account, created/updated via `python manage.py create_auth_user`
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me
ADMIN_EMAIL=you@example.com

TIME_ZONE=Asia/Karachi
